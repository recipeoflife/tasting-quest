---
interface Props {
  en: string;
  title: string;
  message?: string;
}
const { en, title, message = 'このページは現在準備中です。公開まで今しばらくお待ちください。' } = Astro.props;
---

<section class="bg-beige py-24 md:py-36">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 text-center">
    <p class="en-sub text-sm">{en}</p>
    <h1 class="text-3xl md:text-4xl font-bold mt-3">{title}</h1>
    <div class="gold-line mt-10 pt-10">
      <p class="text-charcoal">{message}</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-block border border-brown text-brown px-8 py-3 rounded-full hover:bg-white transition-colors">トップへ戻る</a>
        <a href="/contact" class="inline-block bg-brown text-white px-8 py-3 rounded-full hover:opacity-90 transition-opacity">お問い合わせ</a>
      </div>
    </div>
  </div>
</section>
